2. Write a C program to implement a Hash table using arrays. Perform Insert, Delete and Search operations.
--------------------------------------------------

#include<stdio.h>
#define SIZE 10

int hashTable[SIZE];

int hashFunction(int key)
{
    return key % SIZE;
}

void insert(int key)
{
    int index = hashFunction(key);

    if(hashTable[index] != -1)
        printf("Collision occurred\n");
    else
        hashTable[index] = key;
}

void search(int key)
{
    int index = hashFunction(key);

    if(hashTable[index] == key)
        printf("Element Found\n");
    else
        printf("Element Not Found\n");
}

void delete(int key)
{
    int index = hashFunction(key);

    if(hashTable[index] == key)
    {
        hashTable[index] = -1;
        printf("Element Deleted\n");
    }
    else
        printf("Element Not Found\n");
}

void display()
{
    int i;

    for(i=0;i<SIZE;i++)
        printf("%d -> %d\n",i,hashTable[i]);
}

int main()
{
    int i;

    for(i=0;i<SIZE;i++)
        hashTable[i] = -1;

    insert(23);
    insert(43);

    display();

    search(23);

    delete(23);

    display();

    return 0;
}


