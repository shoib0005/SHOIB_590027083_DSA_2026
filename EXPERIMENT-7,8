4. Write a C program to determine whether graph is undirected or not.
--------------------------------------------------

#include<stdio.h>

int main()
{
    int n,i,j,flag=1;
    int graph[20][20];

    printf("Enter vertices: ");
    scanf("%d",&n);

    printf("Enter adjacency matrix:\n");

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            if(graph[i][j] != graph[j][i])
                flag = 0;

    if(flag)
        printf("Undirected Graph");
    else
        printf("Directed Graph");

    return 0;
}


