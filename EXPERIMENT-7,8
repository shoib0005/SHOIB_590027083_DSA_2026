5. Write a C program to perform Breadth First Search (BFS)
--------------------------------------------------

#include<stdio.h>

int queue[20],front=-1,rear=-1;
int visited[20];

void bfs(int graph[20][20],int n,int start)
{
    int i;

    queue[++rear] = start;
    visited[start] = 1;

    while(front != rear)
    {
        start = queue[++front];
        printf("%d ",start);

        for(i=0;i<n;i++)
        {
            if(graph[start][i] && !visited[i])
            {
                queue[++rear] = i;
                visited[i] = 1;
            }
        }
    }
}

int main()
{
    int graph[20][20];
    int n,i,j,start;

    printf("Enter vertices: ");
    scanf("%d",&n);

    printf("Enter adjacency matrix:\n");

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    printf("Enter starting vertex: ");
    scanf("%d",&start);

    bfs(graph,n,start);

    return 0;
}


