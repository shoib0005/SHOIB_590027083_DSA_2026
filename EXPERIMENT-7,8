3. Write a C program to represent graph using adjacency matrix and find in-degree and out-degree.
--------------------------------------------------

#include<stdio.h>

int main()
{
    int n,i,j,vertex;
    int graph[20][20];
    int indegree=0,outdegree=0;

    printf("Enter number of vertices: ");
    scanf("%d",&n);

    printf("Enter adjacency matrix:\n");

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    printf("Adjacency Matrix:\n");

    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
            printf("%d ",graph[i][j]);
        printf("\n");
    }

    printf("Enter vertex: ");
    scanf("%d",&vertex);

    for(i=0;i<n;i++)
    {
        indegree += graph[i][vertex];
        outdegree += graph[vertex][i];
    }

    printf("In-degree = %d\n",indegree);
    printf("Out-degree = %d\n",outdegree);

    return 0;
}


