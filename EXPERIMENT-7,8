6. Write a C program to perform Depth First Search (DFS)
--------------------------------------------------

#include<stdio.h>

int visited[20];

void dfs(int graph[20][20],int n,int start)
{
    int i;

    printf("%d ",start);
    visited[start] = 1;

    for(i=0;i<n;i++)
        if(graph[start][i] && !visited[i])
            dfs(graph,n,i);
}

int main()
{
    int graph[20][20];
    int n,i,j,start;

    printf("Enter vertices: ");
    scanf("%d",&n);

    printf("Enter adjacency matrix:\n");

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    printf("Enter starting vertex: ");
    scanf("%d",&start);

    dfs(graph,n,start);

    return 0;
}

