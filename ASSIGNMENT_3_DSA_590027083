#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define MAX 100

/* =========================================================
   1. STACK USING ARRAY
========================================================= */
int stack[MAX];
int top = -1;

void push_array(int x) {
    if (top == MAX - 1)
        printf("Stack Overflow\n");
    else {
        stack[++top] = x;
        printf("%d pushed into stack\n", x);
    }
}

void pop_array() {
    if (top == -1)
        printf("Stack Underflow\n");
    else
        printf("%d popped from stack\n", stack[top--]);
}

void display_array() {
    if (top == -1)
        printf("Stack is empty\n");
    else {
        printf("Stack elements:\n");
        for (int i = top; i >= 0; i--)
            printf("%d\n", stack[i]);
    }
}

/* =========================================================
   2. STACK USING LINKED LIST
========================================================= */
struct Node {
    int data;
    struct Node* next;
};

struct Node* top_ll = NULL;

void push_ll(int x) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = x;
    newNode->next = top_ll;
    top_ll = newNode;
}

void pop_ll() {
    if (top_ll == NULL) {
        printf("Stack Underflow\n");
        return;
    }
    struct Node* temp = top_ll;
    printf("%d popped\n", temp->data);
    top_ll = top_ll->next;
    free(temp);
}

void display_ll() {
    struct Node* temp = top_ll;
    printf("Stack elements:\n");
    while (temp != NULL) {
        printf("%d\n", temp->data);
        temp = temp->next;
    }
}

/* =========================================================
   3. REVERSE STRING USING STACK
========================================================= */
void reverse_string() {
    char str[100];
    char stack[100];
    int top = -1;

    printf("Enter string: ");
    scanf("%s", str);

    for (int i = 0; str[i] != '\0'; i++)
        stack[++top] = str[i];

    printf("Reversed string: ");
    while (top != -1)
        printf("%c", stack[top--]);
    printf("\n");
}

/* =========================================================
   4. CHECK BALANCED PARENTHESES
========================================================= */
int isBalanced(char expr[]) {
    char stack[100];
    int top = -1;

    for (int i = 0; expr[i]; i++) {
        char ch = expr[i];

        if (ch == '(' || ch == '{' || ch == '[')
            stack[++top] = ch;
        else if (ch == ')' || ch == '}' || ch == ']') {
            if (top == -1)
                return 0;
            char open = stack[top--];

            if ((ch == ')' && open != '(') ||
                (ch == '}' && open != '{') ||
                (ch == ']' && open != '['))
                return 0;
        }
    }
    return (top == -1);
}

/* =========================================================
   5. INFIX TO POSTFIX
========================================================= */
int precedence(char op) {
    if (op == '^') return 3;
    if (op == '*' || op == '/') return 2;
    if (op == '+' || op == '-') return 1;
    return 0;
}

void infixToPostfix(char infix[]) {
    char stack[100], postfix[100];
    int top = -1, k = 0;

    for (int i = 0; infix[i]; i++) {
        char ch = infix[i];

        if (isalnum(ch))
            postfix[k++] = ch;

        else if (ch == '(')
            stack[++top] = ch;

        else if (ch == ')') {
            while (top != -1 && stack[top] != '(')
                postfix[k++] = stack[top--];
            top--;
        }

        else {
            while (top != -1 && precedence(stack[top]) >= precedence(ch))
                postfix[k++] = stack[top--];
            stack[++top] = ch;
        }
    }

    while (top != -1)
        postfix[k++] = stack[top--];

    postfix[k] = '\0';
    printf("Postfix: %s\n", postfix);
}

/* =========================================================
   6. POSTFIX EVALUATION
========================================================= */
int evaluatePostfix(char exp[]) {
    int stack[100];
    int top = -1;

    for (int i = 0; exp[i]; i++) {
        if (isdigit(exp[i]))
            stack[++top] = exp[i] - '0';

        else {
            int val1 = stack[top--];
            int val2 = stack[top--];

            switch (exp[i]) {
                case '+': stack[++top] = val2 + val1; break;
                case '-': stack[++top] = val2 - val1; break;
                case '*': stack[++top] = val2 * val1; break;
                case '/': stack[++top] = val2 / val1; break;
            }
        }
    }
    return stack[top];
}

/* =========================================================
   MAIN FUNCTION (DEMO)
========================================================= */
int main() {

    // 1. Array Stack Demo
    push_array(10);
    push_array(20);
    pop_array();
    display_array();

    // 2. Linked List Stack Demo
    push_ll(5);
    push_ll(15);
    pop_ll();
    display_ll();

    // 3. Reverse String
    reverse_string();

    // 4. Balanced Expression
    char expr[] = "{[()]}";
    if (isBalanced(expr))
        printf("Balanced Expression\n");
    else
        printf("Not Balanced\n");

    // 5. Infix to Postfix
    char infix[] = "A+B*(C^D-E)^(F+G*H)-I";
    infixToPostfix(infix);

    // 6. Postfix Evaluation
    char postfix[] = "23*54*+9-";
    printf("Result: %d\n", evaluatePostfix(postfix));

    return 0;
}
